{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
    <article class="post-show">
        <h1>{{ post.title }}</h1>

        <div class="post-content">
            {{ post.content|default('')|nl2br }}
        

        <img src =  {{ vich_uploader_asset(post, 'imageFile') }} alt="{{ post.title }}">

        <section class="post-comments">
            <h2>Comments</h2>

            {% if post.comments is not empty %}
                {% for comment in post.comments %}
                    <div class="comment">
                        <strong>{{ comment.username }}</strong>
                        {% if comment.createdAt %}
                            <small>{{ comment.createdAt|date('Y-m-d H:i') }}</small>
                        {% endif %}
                        <p>{{ comment.content }}</p>
                    </div>
                {% endfor %}
            {% else %}
                <p>No comments yet.</p>
            {% endif %}
        </section>

        <section class="post-comment-form">
            <h2>Add a comment</h2>

            {{ form_start(commentForm) }}
                {{ form_row(commentForm.username) }}
                {{ form_row(commentForm.content) }}
                <button type="submit">Send</button>
            {{ form_end(commentForm) }}
        </section>
    </article>
{% endblock %}